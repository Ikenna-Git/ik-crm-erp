## Civis production environment example
## Do not commit real secrets.
## Keep all local-dev fallback flags disabled in production.

## Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

## App URL / routing
NEXTAUTH_URL="https://your-production-domain.com"
NEXT_PUBLIC_APP_URL="https://your-production-domain.com"

## Auth / session
NEXTAUTH_SECRET="replace_with_a_long_random_secret"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

## Founder / super-admin ownership
## The founder super-admin email is currently enforced in lib/authz.ts.
## Change that code intentionally if ownership moves to a new mailbox.

## Shared rate limiting (required for serious production use)
RATE_LIMIT_STORE="upstash"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

## Observability / alerting
OBSERVABILITY_WEBHOOK_URL=""
SECURITY_EVENTS_WEBHOOK_URL=""
ERROR_ALERT_WEBHOOK_URL=""
SENTRY_DSN=""

## Email / SMTP
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Civis <no-reply@yourdomain.com>"

## File storage / uploads
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

## AI providers
AI_PROVIDER="auto"
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
GEMINI_API_KEY=""

## Billing / payment providers
PAYSTACK_PUBLIC_KEY=""
PAYSTACK_SECRET_KEY=""
FLUTTERWAVE_PUBLIC_KEY=""
FLUTTERWAVE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""

## Security / deployment flags
NODE_ENV="production"

## Local-development fallbacks - must remain OFF in production
ALLOW_DEV_HEADER_IDENTITY="false"
ALLOW_DEV_DEFAULT_IDENTITY="false"
NEXTAUTH_ALLOW_DEV_FALLBACK="false"
NEXT_PUBLIC_ENABLE_DEMO_MODE="false"
